-- Auto-build BiomeNames from the Biomes keys. RollWeights kept for legacy callers
-- (anything calling RollBiome without a row context); actual chunk assignment uses RowPools.
BiomeConfig.BiomeNames = {}
for name, _ in pairs(BiomeConfig.Biomes) do
	table.insert(BiomeConfig.BiomeNames, name)
end
table.sort(BiomeConfig.BiomeNames)

BiomeConfig.RollWeights = {}
for _, name in ipairs(BiomeConfig.BiomeNames) do
	BiomeConfig.RollWeights[name] = 1
end

-- Per-row oil presence rate: fraction of tiles in that row's chunks that ACTUALLY have oil
-- under them. Non-oil tiles can still be drilled but yield nothing (turn into dirt patches).
-- SUPER TILEs always have oil regardless of this rate.
-- Keyed by chunk.row (starting row = 4 is nearest to spawn / user's "Row 1").
BiomeConfig.OilRatePerRow = {
	[4] = 0.90,  -- user Row 1 (starter): 90% of tiles have oil
	[3] = 0.70,  -- user Row 2
	[2] = 0.50,  -- user Row 3
	[1] = 0.25,  -- user Row 4 (endgame)
}

-- Row-based biome pools. Keyed by chunk.row (grid row, 1..4). StartingRow = 4 is nearest to spawn.
-- Each pool has 6 biomes; a row's 3 chunks pick DIFFERENT biomes from their pool (no dupes per row).
BiomeConfig.RowPools = {
	[4] = { "DustyDesert", "AncientDesert", "EgyptianDesert", "ArabianDesert", "SmoothDesert", "HotDesert" },
	[3] = { "GrassyFields", "Grasslands", "GrassyForrest", "WetForrest", "Wetlands", "LakeOil" },
	[2] = { "RockyMountains", "LeakyMountain", "MountainSprings", "RockyMeadow", "RockyBoneyard", "AncientTemple" },
	[1] = { "Volcano", "MagmaField", "MagmaPit", "HotRocks", "HotSandyFields", "SteamyFields" },
}

-- Pick a biome for a specific chunk row. `usedInRow` is a Set of biome names already taken
-- by other chunks in the same row; we exclude those so all 3 chunks in a row differ.
function BiomeConfig.RollBiomeForRow(row: number, usedInRow: { [string]: boolean }?, rng: Random?): string
	local pool = BiomeConfig.RowPools[row]
	if not pool or #pool == 0 then
		return BiomeConfig.RollBiome(rng)
	end
	local candidates = {}
	for _, name in ipairs(pool) do
		if not (usedInRow and usedInRow[name]) then
			table.insert(candidates, name)
		end
	end
	if #candidates == 0 then
		-- All 6 already used (shouldn't happen with 3 chunks per row, but safety fallback)
		candidates = pool
	end
	local idx = rng and rng:NextInteger(1, #candidates) or math.random(1, #candidates)
	return candidates[idx]
end

BiomeConfig.SlotMachine = {
	FlashCount = 8,
	InitialInterval = 0.15,
	FinalInterval = 0.8,
}

function BiomeConfig.RollBiome(rng: Random?): string
	local total = 0
	for _, w in pairs(BiomeConfig.RollWeights) do total += w end
	local r = rng and rng:NextInteger(1, total) or math.random(1, total)
	local cursor = 0
	for _, biomeName in ipairs(BiomeConfig.BiomeNames) do
		cursor += BiomeConfig.RollWeights[biomeName] or 0
		if r <= cursor then
			return biomeName
		end
	end
	return "DustyDesert"
end

function BiomeConfig.RollTileType(biomeName: string, rng: Random?)
	local biome = BiomeConfig.Biomes[biomeName]
	if not biome or not biome.tileTypes or #biome.tileTypes == 0 then
		return { name = "Sand", oilTypes = { { oilType = "HeavyCrude", weight = 100 } }, weight = 100, drillSeconds = 30, material = Enum.Material.Sand, color = Color3.fromRGB(254, 224, 180) }
	end
	local totalWeight = 0
	for _, tt in ipairs(biome.tileTypes) do totalWeight += tt.weight end
	local r = rng and rng:NextInteger(1, totalWeight) or math.random(1, totalWeight)
	local cursor = 0
	for _, tt in ipairs(biome.tileTypes) do
		cursor += tt.weight
		if r <= cursor then return tt end
	end
	return biome.tileTypes[1]
end

-- Given a tileType from the config, pick ONE oil type from its `oilTypes` array
-- (or fall back to legacy `oilType` field). Called at chunk generation time so each
-- tile instance gets exactly one oil type baked in.
function BiomeConfig.PickOilType(tileType: any, rng: Random?): string
	if not tileType then return "HeavyCrude" end
	local oilTypes = tileType.oilTypes
	if typeof(oilTypes) == "table" and #oilTypes > 0 then
		local total = 0
		for _, ot in ipairs(oilTypes) do total += (ot.weight or 1) end
		if total <= 0 then return oilTypes[1].oilType or "HeavyCrude" end
		local r = rng and rng:NextInteger(1, total) or math.random(1, total)
		local cursor = 0
		for _, ot in ipairs(oilTypes) do
			cursor += (ot.weight or 1)
			if r <= cursor then return ot.oilType or "HeavyCrude" end
		end
		return oilTypes[1].oilType or "HeavyCrude"
	end
	return tileType.oilType or "HeavyCrude"
end

function BiomeConfig.RollTileOilType(biomeName: string, rng: Random?): string
	local tt = BiomeConfig.RollTileType(biomeName, rng)
	return BiomeConfig.PickOilType(tt, rng)
end

-- Obstacle system removed. Stub remains for any stale callers.
function BiomeConfig.IsPipesOnlyObstacle(_obstacleType: string): boolean
	return false
end

return BiomeConfig
