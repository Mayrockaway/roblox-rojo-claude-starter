{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(claude mcp *)",
      "Bash(gh release *)",
      "Bash(npm view *)",
      "Bash(npm pack *)",
      "Bash(npx robloxstudio-mcp@latest --version)",
      "Bash(netstat -ano)",
      "Read(//tmp/**)",
      "mcp__robloxstudio-mcp__get_place_info",
      "mcp__robloxstudio-mcp__get_instance_children"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "robloxstudio-mcp"
  ]
}
